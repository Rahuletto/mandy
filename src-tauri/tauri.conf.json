{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Mandy",
	"version": "1.0.1",
	"identifier": "com.marban.mandy",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "Mandy",
				"transparent": true,
				"titleBarStyle": "Overlay",
				"width": 1200,
				"height": 800,
				"hiddenTitle": true,
				"dragDropEnabled": true,
				"trafficLightPosition": {
					"x": 18,
					"y": 22
				}
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4NDg1RjJBMzVEQUQ5NzkKUldSNTJkbzFLbDlJNktKUG9acUYvM0QzQU84S2gyVXdBb040RFRBMHBQejVDUk9VdWlWU285YUIK",
			"endpoints": [
				"https://github.com/Rahuletto/mandy/releases/latest/download/latest.json"
			]
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": "all",
		"resources": [
			"resources/macos-tahoe-tinted-dark.png",
			"resources/macos-tahoe-light.png",
			"resources/mandy-about-icon.png",
			"resources/mandy-about-icon-dark.png"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"fileAssociations": [
			{
				"ext": ["mandy.json"],
				"mimeType": "application/x-mandy+json",
				"name": "Mandy Project"
			}
		]
	}
}
