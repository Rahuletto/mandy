{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!!**/src-tauri/target", "!!**/.vite", "!!**/coverage"]
	},
	"formatter": {
		"enabled": true
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": false
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noImportantStyles": "off"
			},
			"nursery": {
				"useSortedClasses": "warn"
			},
			"a11y": {
				"noLabelWithoutControl": "warn",
				"noStaticElementInteractions": "warn",
				"useKeyWithClickEvents": "warn",
				"noSvgWithoutTitle": "warn",
				"useMediaCaption": "warn"
			},
			"suspicious": {
				"noExplicitAny": "warn"
			},
			"style": {
				"noNonNullAssertion": "warn"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/bindings.ts"],
			"formatter": {
				"enabled": false
			},
			"assist": {
				"enabled": false
			},
			"linter": {
				"enabled": false
			}
		},
		{
			"includes": [
				"src/components/FileTree.tsx",
				"src/components/ui/ContextMenu.tsx",
				"src/components/ui/Dropdown.tsx"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": [
				"src/utils/migration/**/*.ts",
				"src/migration/**/*.ts",
				"src/utils/hardenedsandbox.ts",
				"src/utils/overviewUtils.ts",
				"src/types/overview.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noExplicitAny": "off"
					}
				}
			}
		}
	]
}
